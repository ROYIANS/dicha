# dicha self-hosted — copy to `.env` and adjust before first deploy
# ────────────────────────────────────────────────────────────
POSTGRES_USER=dicha
POSTGRES_PASSWORD=changeme
POSTGRES_DB=dicha
# Leave empty to keep Postgres internal-only (recommended for production)
POSTGRES_PORT=5432

# ── API (NestJS backend) ───────────────────────────────────────────────────────
# DATABASE_URL is auto-constructed in docker-compose.yml from POSTGRES_* above
PORT=3000

# ── Better Auth (self-hosted auth library, runs inside the API process) ────────
# 32+ char random secret: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-secret-at-least-32-chars
# Public origin of the API (basePath defaults to /api/auth)
BETTER_AUTH_URL=http://localhost:3000

# ── ALTCHA (proof-of-work gate on email OTP send, anti-abuse) ──────────────────
# Self-hosted PoW HMAC secret. Gates /api/auth/email-otp/send-verification-otp so
# bots can't spam login emails. Required — the API fails to boot without it.
# 32+ char random secret: openssl rand -base64 32
ALTCHA_HMAC_SECRET=change-me-to-a-random-secret-at-least-32-chars

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create an OAuth App at https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

# ── SMTP (email verification + password reset, via your own mail provider) ─────
# Gmail: use an app password; QQ mail: use an authorization code. 465=SSL, 587=STARTTLS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-account@gmail.com
SMTP_PASS=your-smtp-app-password
SMTP_FROM="dicha <your-account@gmail.com>"

# ── Uploads (user media: avatars) ──────────────────────────────────────────────
# Where the API writes uploaded files. In docker-compose this is set to
# /data/uploads (a named volume) — only override for local non-docker dev.
# UPLOAD_DIR=./uploads

# ── AI Gateway (provider/model config + encrypted secrets) ─────────────────────
# Internal URL used by the API container. Keep the default for the bundled
# docker-compose stack; override only when ai-gateway runs outside this compose
# network.
AI_GATEWAY_BASE_URL=http://ai-gateway:3100/ai
# Shared internal token used by api -> ai-gateway proxy calls.
# 32+ char random secret: openssl rand -base64 32
AI_GATEWAY_INTERNAL_TOKEN=change-me-to-a-random-secret-at-least-32-chars
# Encryption key for write-only provider credentials stored by ai-gateway.
# Rotate carefully: existing encrypted credentials cannot be read with a new key.
# 32+ char random secret: openssl rand -base64 32
AI_GATEWAY_SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars

# ── Web (public entrypoint) ────────────────────────────────────────────────────
WEB_PORT=8080

# ── Container images (pulled from GHCR; built by GitHub Actions on push to main) ─
# Override IMAGE_TAG to pin a specific commit, e.g. sha-<full-git-sha>.
IMAGE_PREFIX=ghcr.io/royians/dicha
IMAGE_TAG=latest

# ── Web build-time flags (baked into the image at CI build time) ────────────────
# NOTE: VITE_* values are inlined when the web image is built in CI — changing them
# here has no effect on a pulled image. To change them, set repo variables
# (VITE_UMAMI_*) and re-run the workflow, or deploy with `--build` to build locally.
# Same-origin /api — nginx proxies to the api service; do not change unless you
# run a separate API gateway.
VITE_API_BASE_URL=/api

# ── Umami analytics (optional — baked into web bundle at build time) ───────────
# VITE_UMAMI_SCRIPT_URL=https://analytics.example.com/script.js
# VITE_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
