# vidorra self-hosted — copy to `.env` and adjust before first deploy
#   cp .env.example .env

# ── Postgres ───────────────────────────────────────────────────────────────────
POSTGRES_USER=vidorra
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=vidorra
# Leave empty to keep Postgres internal-only (recommended for production)
POSTGRES_PORT=5432

# ── API (NestJS backend) ───────────────────────────────────────────────────────
# DATABASE_URL is auto-constructed in docker-compose.yml from POSTGRES_* above
PORT=3000
SESSION_SECRET=change-me-to-a-random-secret-at-least-32-chars

# ── Casdoor (self-hosted OAuth/OIDC) ──────────────────────────────────────────
# Casdoor runs in docker-compose as `casdoor` service on port 8000
CASDOOR_PORT=8000
# External origin for Casdoor (must match CASDOOR_ENDPOINT below)
CASDOOR_ORIGIN=http://localhost:8000

# API connects to Casdoor via this endpoint
CASDOOR_ENDPOINT=http://localhost:8000
CASDOOR_CLIENT_ID=your-app-client-id
CASDOOR_CLIENT_SECRET=your-app-client-secret
CASDOOR_ORG=your-org-name
CASDOOR_APP=your-app-name
CASDOOR_CALLBACK_URL=http://localhost:3000/api/auth/callback

# ── Web (public entrypoint) ────────────────────────────────────────────────────
WEB_PORT=8080

# ── Web build-time flags (baked into static bundle on `docker compose build`) ─
# Same-origin /api — nginx proxies to the api service; do not change unless you
# run a separate API gateway.
VITE_API_BASE_URL=/api
# true = skip auth guard (for dev/demo), false = require Casdoor login
VITE_DEV_BYPASS_AUTH=true

# ── Umami analytics (optional — baked into web bundle at build time) ───────────
# VITE_UMAMI_SCRIPT_URL=https://analytics.example.com/script.js
# VITE_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
