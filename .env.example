# vidorra self-hosted — copy to `.env` and adjust before first deploy
#   cp .env.example .env

# ── Postgres ───────────────────────────────────────────────────────────────────
POSTGRES_USER=vidorra
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=vidorra
# Leave empty to keep Postgres internal-only (recommended for production)
POSTGRES_PORT=5432

# ── Web (public entrypoint) ────────────────────────────────────────────────────
WEB_PORT=8080

# ── Web build-time flags (baked into static bundle on `docker compose build`) ─
# Same-origin /api — nginx proxies to the api service; do not change unless you
# run a separate API gateway.
VITE_API_BASE_URL=/api
# true = skip auth guard until Casdoor BFF lands (convenient for self-host demo)
VITE_DEV_BYPASS_AUTH=true

# ── Umami analytics (optional — baked into web bundle at build time) ───────────
# VITE_UMAMI_SCRIPT_URL=https://analytics.example.com/script.js
# VITE_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
