# Postgres (matches docker-compose.yml)
DATABASE_URL="postgresql://dicha:dicha@localhost:5432/dicha?schema=public"

# API
PORT=3000

# ── Better Auth ───────────────────────────────────────────────────────────────
# 32+ 字符随机串：openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-secret-at-least-32-chars
# 后端对外 origin，basePath 默认 /api/auth
# 生产填 API 实际 origin，例如 https://api.dicha.life。
BETTER_AUTH_URL=http://localhost:3000
# 浏览器前端 origin。前台和后台分属不同域名时必须都填，供 passkey origin 校验
# 和 OAuth 登录后回跳使用，例如 https://dicha.life / https://admin.dicha.life。
DICHA_WEB_ORIGIN=http://localhost:5173
DICHA_ADMIN_ORIGIN=http://localhost:5174
# 生产填前台和后台共同所属的可注册根域名，例如 dicha.life / example.com。
# DICHA_PASSKEY_RP_ID=dicha.life
# 逗号分隔。命中的登录邮箱会获得内部/管理员页面入口。
DICHA_SUPER_ADMIN_EMAILS=you@example.com

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# 在 https://github.com/settings/developers 新建 OAuth App，
# Authorization callback URL 填：http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

# ── SMTP（邮箱 OTP 登录验证码，用你自有邮箱服务）─────────────────────────────
# 例：Gmail 用应用专用密码；QQ 邮箱用授权码。465=SSL，587=STARTTLS。
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-account@gmail.com
SMTP_PASS=your-smtp-app-password
SMTP_FROM="dicha <your-account@gmail.com>"
