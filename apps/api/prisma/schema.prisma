// dicha-life · v0 数据模型（M1 Week 1-2）
// 约定见 .trellis/spec/backend/database-guidelines.md
// 显式关系命名 / 硬删除（断舍离 g1）/ coins schema MVP 就装 / 互动统一进 Event

generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "cjs"
  runtime             = "nodejs"
  importFileExtension = "js"
}

generator aiGatewayClient {
  provider            = "prisma-client"
  output              = "../../ai-gateway/src/generated/prisma"
  moduleFormat        = "cjs"
  runtime             = "nodejs"
  importFileExtension = "js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum RoomType {
  STORAGE_ROOM
  WARDROBE
  LIBRARY
}

enum StickerSource {
  AI
  LIBRARY
  USER
}

enum PoemAuthorType {
  DEFAULT_POOL
  USER
  AI
}

enum PoemVisibility {
  PRIVATE
  FRIEND
}

enum EventType {
  CREATED
  CHECK_IN
  WORN
  READ
  CLEANED_DUST
}

// ─── Models ──────────────────────────────────────────────

// User 表 = Better Auth 身份表 + 领域 User（单一身份源，决策 2）。
// id 保留 cuid()（决策 6：advanced.database.generateId=false → Prisma DB 侧默认接管）。
model User {
  id String @id @default(cuid())

  // ── Better Auth 必需列 ──────────────────────────────────
  name           String
  email          String    @unique
  emailVerified  Boolean   @default(false)
  image          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  status         String    @default("active")
  disabledAt     DateTime?
  disabledReason String?
  disabledById   String?

  // ── dicha 应用字段（additionalFields）────────────────
  displayName          String
  city                 String?
  gender               String?
  bio                  String?
  personalityArchetype String?
  homeName             String?

  // 游戏内金币：MVP 仅 schema + 显示，无消费场景（避免 v2 迁移）
  coins Int @default(0)

  // ── Better Auth 关系 ───────────────────────────────────
  sessions Session[]
  accounts Account[]
  passkeys Passkey[]

  // ── 领域关系 ───────────────────────────────────────────
  items  Item[]
  events Event[]

  // ── AI Gateway 关系 ───────────────────────────────────
  aiProviders         AiProviderConfig[]
  aiModels            AiModelConfig[]
  aiAssignments       AiModelAssignmentConfig[]
  aiUsageEvents       AiUsageEvent[]
  creditAccount       CreditAccount?
  creditLedgerEntries CreditLedgerEntry[]
  creditRedemptions   CreditRedemption[]

  @@index([status, createdAt])
  @@index([emailVerified, createdAt])
}

model AdminAuditLog {
  id String @id @default(cuid())

  actorId    String?
  actorEmail String?
  actorName  String?

  action       String
  resourceType String
  resourceId   String?
  result       String
  ipAddress    String?
  userAgent    String?
  summary      String
  metadata     Json?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([resourceType, resourceId, createdAt])
  @@index([result, createdAt])
}

// ─── Better Auth 表（session / account / verification）───
// 字段对齐 Better Auth Prisma adapter 期望；显式关系命名遵循 database-guidelines.md。

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?

  owner  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  owner  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
}

// passkey 插件表（WebAuthn 凭证）。字段对齐 @better-auth/passkey adapter 期望。
model Passkey {
  id           String  @id @default(cuid())
  name         String?
  publicKey    String
  credentialID String
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?
  aaguid       String?

  owner  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())

  @@index([userId])
}

model Category {
  id       String   @id @default(cuid())
  key      String   @unique // 稳定标识，如 "tops" / "books"
  name     String
  roomType RoomType

  // 每类目独立可配落灰曲线（落灰只对物品 sprite）
  dustCurve Json?

  items Item[]
  poems Poem[] // 类目默认诗池（诗永不为空）

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Item {
  id       String   @id @default(cuid())
  name     String
  roomType RoomType
  notes    String?

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String

  // sticker 可空：AI/库匹配都失败时用文字占位（永不阻塞录入）
  sticker   Sticker? @relation(fields: [stickerId], references: [id])
  stickerId String?

  poems  Poem[]
  events Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([categoryId])
}

model Sticker {
  id          String        @id @default(cuid())
  name        String
  description String? // M2 用于 embedding 智能匹配
  imageUrl    String
  source      StickerSource

  items Item[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Poem {
  id         String         @id @default(cuid())
  content    String
  order      Int            @default(0) // c1 一句，留多句空间（v2 诗的卷轴）
  authorType PoemAuthorType
  visibility PoemVisibility @default(PRIVATE)
  archivedAt DateTime? // 用户编辑诗 → 旧版归档（v2 诗的考古层）

  // 二选一：绑定到具体 item，或作为 category 默认诗池
  item       Item?     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId     String?
  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([itemId])
  @@index([categoryId])
}

model Event {
  id       String    @id @default(cuid())
  type     EventType
  roomType RoomType?
  metadata Json? // 房间特有事件载荷（衣橱"穿了"、书房"读了"等）

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  item   Item?   @relation(fields: [itemId], references: [id], onDelete: SetNull)
  itemId String?

  createdAt DateTime @default(now())

  @@index([ownerId])
  @@index([itemId])
  @@index([type])
}

// ─── AI Gateway 持久化（用户维度 + 系统托管渠道）──────────

model AiProviderDirectorySetting {
  providerId    String  @id
  enabled       Boolean @default(false)
  baseUrl       String?
  requestFormat String?
  authType      String?
  modelSyncMode String?
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled, providerId])
}

model AiProviderDirectoryModel {
  id      String @id @default(cuid())
  modelId String

  providerId String

  name                String
  displayName         String
  avatar              String?
  contextWindow       Int?
  modelType           String
  extensionParameters Json
  capabilities        Json
  maxOutput           Int?
  enabled             Boolean @default(false)
  recommended         Boolean @default(false)
  availability        String  @default("unknown")
  priceHint           String
  catalogSource       String?
  pricing             Json?
  releasedAt          String?
  lobeMetadata        Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([providerId, modelId])
  @@index([providerId, enabled])
}

model AiProviderConfig {
  id         String @id @default(cuid())
  providerId String

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  name            String
  shortName       String
  avatar          String?
  description     String
  baseUrl         String
  status          String
  category        String
  authType        String
  requestFormat   String?
  credentialMode  String
  billingMode     String
  modelSyncMode   String
  credentialState String
  priority        Int
  custom          Boolean?
  credential      Json?

  models AiModelConfig[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, providerId])
  @@index([ownerId])
  @@index([ownerId, status, priority])
}

model AiModelConfig {
  id      String @id @default(cuid())
  modelId String

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  provider   AiProviderConfig @relation(fields: [ownerId, providerId], references: [ownerId, providerId], onDelete: Cascade)
  providerId String

  name                String
  displayName         String
  avatar              String?
  contextWindow       Int?
  modelType           String
  extensionParameters Json
  capabilities        Json
  maxOutput           Int?
  enabled             Boolean
  recommended         Boolean
  availability        String
  lastLatencyMs       Int?
  priceHint           String
  catalogSource       String?
  pricing             Json?
  releasedAt          String?
  lobeMetadata        Json?
  custom              Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, modelId])
  @@index([ownerId])
  @@index([ownerId, providerId, enabled])
  @@index([ownerId, availability])
}

model AiModelAssignmentConfig {
  id      String @id @default(cuid())
  useCase String

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  primaryModelId   String
  fallbackModelIds Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, useCase])
  @@index([ownerId])
}

model AiUsageEvent {
  id String @id

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  kind                    String
  status                  String
  useCase                 String
  providerId              String
  providerName            String
  modelId                 String
  modelName               String
  promptTokens            Int
  completionTokens        Int
  totalTokens             Int
  estimatedCostUsd        Float
  estimatedCostAmount     Float
  estimatedCostCurrency   String?
  creditAmount            Int      @default(0)
  billingMode             String   @default("user_provider")
  requestId               String?
  upstreamRequestId       String?
  internalProviderId      String?
  internalProviderModelId String?
  creditLedgerEntryId     String?
  usageEstimated          Boolean  @default(false)
  billingSnapshot         Json?
  latencyMs               Int?
  errorCategory           String?
  createdAt               DateTime @default(now())

  @@index([ownerId, createdAt])
  @@index([ownerId, providerId, createdAt])
  @@index([ownerId, modelId, createdAt])
  @@index([ownerId, useCase, createdAt])
  @@index([ownerId, status, createdAt])
  @@index([ownerId, billingMode, createdAt])
  @@index([providerId, createdAt])
  @@index([providerId, status, createdAt])
  @@index([providerId, errorCategory, createdAt])
  @@index([providerId, modelId, createdAt])
  @@index([providerId, internalProviderModelId, createdAt])
  @@index([providerId, internalProviderId, createdAt])
  @@index([providerId, estimatedCostCurrency, createdAt])
  @@index([providerId, billingMode, createdAt])
  @@index([requestId])
  @@index([creditLedgerEntryId])
}

// ─── Credit System（积分与官方 AI 消费）────────────────────

model CreditAccount {
  id String @id @default(cuid())

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String @unique

  balance         Int @default(0)
  lifetimeGranted Int @default(0)
  lifetimeSpent   Int @default(0)

  ledgerEntries CreditLedgerEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([balance])
}

model CreditLedgerEntry {
  id String @id @default(cuid())

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  account   CreditAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId String

  type           String
  amount         Int
  balanceAfter   Int
  source         String
  sourceId       String?
  aiUsageEventId String?
  description    String?
  metadata       Json?

  redemption CreditRedemption?

  createdAt DateTime @default(now())

  @@index([ownerId, createdAt])
  @@index([ownerId, type, createdAt])
  @@index([createdAt])
  @@index([type, createdAt])
  @@index([source, sourceId])
  @@index([aiUsageEventId])
}

model CreditRule {
  id String @id @default(cuid())

  name                 String
  active               Boolean @default(false)
  cnyCreditsPerUnit    Int     @default(1000)
  usdCreditsPerUnit    Int     @default(7000)
  platformMarkup       Float   @default(1)
  minimumChargeCredits Int     @default(1)
  notes                String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, updatedAt])
}

model CreditRedemptionCode {
  id String @id @default(cuid())

  code           String    @unique
  creditAmount   Int
  enabled        Boolean   @default(true)
  maxRedemptions Int       @default(1)
  redeemedCount  Int       @default(0)
  expiresAt      DateTime?
  notes          String?

  redemptions CreditRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled, expiresAt])
}

model CreditRedemption {
  id String @id @default(cuid())

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  code   CreditRedemptionCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  codeId String

  ledgerEntry   CreditLedgerEntry? @relation(fields: [ledgerEntryId], references: [id], onDelete: SetNull)
  ledgerEntryId String?            @unique

  createdAt DateTime @default(now())

  @@unique([ownerId, codeId])
  @@index([ownerId, createdAt])
  @@index([codeId, createdAt])
}

model AiSystemProviderChannel {
  id String @id @default(cuid())

  providerId        String
  modelId           String
  name              String
  upstreamBaseUrl   String
  upstreamModelName String
  requestFormat     String
  authType          String
  credential        Json?
  enabled           Boolean @default(false)
  priority          Int     @default(100)
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([providerId, modelId, enabled, priority])
}

model AiInternalProvider {
  id String @id @default(cuid())

  name          String
  baseUrl       String
  requestFormat String
  authType      String
  credential    Json?
  enabled       Boolean @default(false)
  priority      Int     @default(100)
  notes         String?

  models AiInternalProviderModel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled, priority])
}

model AiInternalProviderModel {
  id String @id @default(cuid())

  internalProvider   AiInternalProvider @relation(fields: [internalProviderId], references: [id], onDelete: Cascade)
  internalProviderId String

  upstreamModelName   String
  upstreamDisplayName String
  modelType           String
  capabilities        Json
  contextWindow       Int?
  maxOutput           Int?
  pricing             Json?
  releasedAt          String?
  enabled             Boolean @default(false)
  availability        String  @default("unknown")

  dxModelId       String?
  dxDisplayName   String?
  dxDescription   String?
  dxPriceHint     String?
  dxPricing       Json?
  dxRecommended   Boolean @default(false)
  dxSortOrder     Int     @default(100)
  parameterConfig Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([internalProviderId, upstreamModelName])
  @@index([internalProviderId, enabled])
  @@index([dxModelId, enabled])
}
