# Copy to `.env.local` to override Vite dev defaults.

# Same-origin /api via vite.config server.proxy
VITE_API_BASE_URL=/api

# ── Umami analytics (optional — both required to enable) ─────────────────────
# Self-hosted or Umami Cloud script endpoint + website ID from dashboard.
# Leave unset in local dev to skip tracking.
# VITE_UMAMI_SCRIPT_URL=https://analytics.example.com/script.js
# VITE_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
